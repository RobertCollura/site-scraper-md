# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Required for JS-rendered pages. Get a free key at https://firecrawl.dev
# When absent the scraper falls back to a basic static HTTP fetch.
FIRECRAWL_API_KEY=fc-...

# ── General ───────────────────────────────────────────────────────────────────
# Optional: override default User-Agent for static HTTP fallback fetches
DEFAULT_USER_AGENT="SiteScraperMD/1.0 (+https://github.com/site-scraper-md; respectful scraper)"

# Directory for exported Markdown (gitignored). Override with OUTPUT_DIR.
OUTPUT_DIR=output
